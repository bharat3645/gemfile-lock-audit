#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require_relative "../lib/gemfile_lock_audit"

module GemfileLockAudit
  module CLI
    module_function

    def run(argv)
      options = { fail_under: nil }
      parser = OptionParser.new do |opts|
        opts.banner = "Usage: gemfile-lock-audit [options] PATH_TO_GEMFILE.LOCK [more paths...]"
        opts.on("--fail-under N", Float, "Exit non-zero if any score is below N") do |n|
          options[:fail_under] = n
        end
        opts.on("-h", "--help", "Show this help") do
          puts opts
          return 0
        end
      end

      paths = parser.parse(argv)
      paths = ["Gemfile.lock"] if paths.empty?

      exit_code = 0
      reports = []

      paths.each do |path|
        begin
          report = Scanner.scan_file(path)
        rescue ParseError => e
          warn "#{path}: #{e.message}"
          exit_code = 1
          next
        end

        reports << report
        print_report(report)

        if options[:fail_under] && report.score < options[:fail_under]
          exit_code = 1
        end
      end

      exit_code
    end

    def print_report(report)
      puts report.path
      puts "=" * report.path.length
      puts
      if report.findings.empty?
        puts "No findings."
      else
        report.findings.each do |f|
          tag = f.severity.to_s.upcase.rjust(8)
          puts "  [#{tag}] #{f.rule_id}: #{f.message}"
        end
      end
      puts
      puts "Score: #{report.score}/100 (grade #{report.grade})"
      puts
    end
  end
end

exit(GemfileLockAudit::CLI.run(ARGV)) if $PROGRAM_NAME == __FILE__
